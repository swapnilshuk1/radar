datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model DiscoveredJob {
  id                  String    @id @default(uuid())
  title               String
  company             String
  location            String
  sourcePortal        String
  url                 String    @unique
  snippet             String
  matchScore          Int
  rankingData         String?   // JSON-serialised RankingExplanation
  rankingVersion      String?
  rankingConfigVersion String?
  semanticData        String?   // Cached JSON: { overallScore, confidence, summary, strengths[], gaps[] }
  status              String    @default("New") // "New", "Reviewed", "Archived"
  scrapedAt           DateTime  @default(now())

  // Telemetry, Caching & Prompt Versioning Columns (V4.0)
  jobHash             String?
  promptVersion       String?
  modelName           String?
  temperature         Float?
  inputTokens         Int?
  outputTokens        Int?
  latencyMs           Int?
  costUsd             Float?

  @@index([jobHash])
}
