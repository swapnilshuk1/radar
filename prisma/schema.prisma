datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model DiscoveredJob {
  id                  String    @id @default(uuid())
  title               String
  company             String
  location            String
  sourcePortal        String
  url                 String    @unique
  normalizedUrl       String?   @unique // Unique index on normalized URL
  snippet             String
  matchScore          Int
  rankingData         String?   // JSON-serialised RankingExplanation
  rankingVersion      String?
  rankingConfigVersion String?
  semanticData        String?   // Cached JSON: { overallScore, confidence, summary, strengths[], gaps[] }
  status              String    @default("New") // "New", "Reviewed", "Archived"
  scrapedAt           DateTime  @default(now())

  // Telemetry, Caching & Prompt Versioning Columns (V4.0)
  jobHash             String?
  promptVersion       String?
  modelName           String?
  temperature         Float?
  inputTokens         Int?
  outputTokens        Int?
  latencyMs           Int?
  costUsd             Float?
  rejected            Boolean   @default(false) // Explicit rejected flag
  versions            String?   // JSON-serialised VersionManifest snapshot (item 8)

  @@index([jobHash])
  @@index([scrapedAt])
  @@index([matchScore])
  @@index([rejected])
}
